<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.nong.mapper.NbExpertMapper">

    <resultMap id="BaseResultMap" type="org.nong.entity.NbExpert">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="avatar" column="avatar"/>
        <result property="specialty" column="specialty"/>
        <result property="title" column="title"/>
        <result property="organization" column="organization"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="introduction" column="introduction"/>
        <result property="serviceCount" column="service_count"/>
        <result property="rating" column="rating"/>
        <result property="status" column="status"/>
    </resultMap>

    <sql id="selectColumns">
        id, name, avatar, specialty, title, organization, phone, email,
        introduction, service_count, rating, status
    </sql>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="selectColumns"/>
        FROM nb_expert
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="specialty != null and specialty != ''">
                AND specialty LIKE CONCAT('%', #{specialty}, '%')
            </if>
            <if test="organization != null and organization != ''">
                AND organization LIKE CONCAT('%', #{organization}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY service_count DESC, id DESC
        <if test="offset != null and pageSize != null">
            LIMIT #{offset}, #{pageSize}
        </if>
    </select>

    <select id="selectCount" resultType="long">
        SELECT COUNT(*) FROM nb_expert
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="specialty != null and specialty != ''">
                AND specialty LIKE CONCAT('%', #{specialty}, '%')
            </if>
            <if test="organization != null and organization != ''">
                AND organization LIKE CONCAT('%', #{organization}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="selectColumns"/>
        FROM nb_expert WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO nb_expert (
            id, name, avatar, specialty, title, organization, phone, email,
            introduction, service_count, rating, status
        ) VALUES (
            #{id}, #{name}, #{avatar}, #{specialty}, #{title}, #{organization}, #{phone}, #{email},
            #{introduction}, #{serviceCount}, #{rating}, #{status}
        )
    </insert>

    <update id="update">
        UPDATE nb_expert
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="specialty != null">specialty = #{specialty},</if>
            <if test="title != null">title = #{title},</if>
            <if test="organization != null">organization = #{organization},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="introduction != null">introduction = #{introduction},</if>
            <if test="serviceCount != null">service_count = #{serviceCount},</if>
            <if test="rating != null">rating = #{rating},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM nb_expert WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM nb_expert WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

