<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.nong.mapper.NbAdvertisementMapper">

    <resultMap id="BaseResultMap" type="org.nong.entity.NbAdvertisement">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="image" column="image"/>
        <result property="position" column="position"/>
        <result property="linkUrl" column="link_url"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="clickCount" column="click_count"/>
    </resultMap>

    <sql id="selectColumns">
        id, title, image, position, link_url, start_time, end_time,
        sort, status, click_count
    </sql>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="selectColumns"/>
        FROM nb_advertisement
        <where>
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="position != null and position != ''">
                AND position = #{position}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort ASC, id DESC
        <if test="offset != null and pageSize != null">
            LIMIT #{offset}, #{pageSize}
        </if>
    </select>

    <select id="selectCount" resultType="long">
        SELECT COUNT(*) FROM nb_advertisement
        <where>
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="position != null and position != ''">
                AND position = #{position}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="selectColumns"/>
        FROM nb_advertisement WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO nb_advertisement (
            id, title, image, position, link_url, start_time, end_time,
            sort, status, click_count
        ) VALUES (
            #{id}, #{title}, #{image}, #{position}, #{linkUrl}, #{startTime}, #{endTime},
            #{sort}, #{status}, #{clickCount}
        )
    </insert>

    <update id="update">
        UPDATE nb_advertisement
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="image != null">image = #{image},</if>
            <if test="position != null">position = #{position},</if>
            <if test="linkUrl != null">link_url = #{linkUrl},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="clickCount != null">click_count = #{clickCount},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM nb_advertisement WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM nb_advertisement WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

